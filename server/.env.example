# LLM - Cloud (OpenRouter)：前端下拉选项，逗号分隔；LABELS 条数需与 MODELS 对齐
# 带「经济」标签的模型单价更低，适合反复 Plan/Agent 调试；标准档用于效果对比
OPENROUTER_API_KEY=YOUR_KEY
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MODELS=openrouter/auto,google/gemini-2.5-flash-lite,openai/gpt-4o-mini,deepseek/deepseek-chat,openrouter/anthropic/claude-3.5-sonnet,openrouter/google/gemini-2.0-flash-001
OPENROUTER_LABELS=Auto,Gemini Lite（经济）,GPT-4o mini（经济）,DeepSeek（经济）,Claude 3.5（标准）,Gemini 2.0 Flash（标准）

# LLM - Local (Ollama)：目前仅一个选项
# 启动后端时自动启动 Ollama（若未运行）；设为 0 禁用
AUTO_START_OLLAMA=1
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=qwen2.5:7b
OLLAMA_LABELS=qwen2.5:7b

# Debug only: when PA structured Plan is missing, parse assistant text as JSON (not for production)
# AGENT_PA_PLAN_JSON_FALLBACK=1

# SQLite audit log (HTTP requests + LLM calls); local debug only — may contain spreadsheet samples
# AUDIT_DB_ENABLED=1
# AUDIT_DB_PATH=data/audit.sqlite3
# AUDIT_MAX_BODY_CHARS=50000
# AUDIT_STORE_WORKSPACE_KEY=0
# LLM_DEBUG_LOG_DIR=logs/llm-debug
# LLM_DEBUG_MAX_CHARS=50000
# SESSION_MEMORY_DB_ENABLED=0
# SESSION_MEMORY_TTL_DAYS=7
